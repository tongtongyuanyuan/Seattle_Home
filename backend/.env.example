# --- Google Sheets (data source) ---
# Option 1: file path (recommended for local dev)
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/gcp-service-account.json

# Option 2: JSON string (for deploy platforms like Render)
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# Google Sheet ID (from the spreadsheet URL)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Sheet tab names
OPEN_HOUSE_TAB=open_house_picks
LEADS_TAB=leads

# --- LLM / embeddings (OPTIONAL) ---
# Leave unset to run fully deterministic, free, no external calls.
# Set a key + `poetry install --with ai` to enable semantic search + LLM answers.
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

# --- Email notifications for new tour requests (OPTIONAL) ---
# Leave unset to skip emails (leads are still saved to the sheet).
# For Gmail: enable 2-Step Verification, then create an App Password
# (Google Account > Security > App passwords) and use it as SMTP_PASSWORD.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=tongxue616@gmail.com
# SMTP_PASSWORD=your_16_char_app_password
# FROM_EMAIL=tongxue616@gmail.com
# NOTIFY_EMAILS=tongxue616@gmail.com,rachelxue@kw.com

# --- Server ---
PORT=8000
